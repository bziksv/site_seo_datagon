# Скопируйте в .github/workflows/ci.yml после push (нужен PAT с scope workflow или добавление через GitHub UI)
name: CI

on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: "20"
          cache: npm

      - run: npm ci
      - run: npm run lint
      - run: npm run build
        env:
          NEXT_PUBLIC_LK_URL: https://lk.redbox.su
          LK_API_BASE_URL: https://lk.redbox.su
